---
// import { imgLine11, imgPolygon3 } from './svg-8mznc'; // SVGインポートは保留
const imgLine11 = "";
const imgPolygon3 = "";
const imgSolaIcon2 = "/images/9a0db4737d90db51fd68f7cb1eb5ed75b077fc51.png";

const newsItems = [
  {
    date: "2026年4月9日(木)",
    text: "Webサイトをリニューアルしました",
  },
  {
    date: "2026年3月16日（月）",
    text: `イメージフォーラム & YouTubeにて「特報」予告(…)`,
  },
  {
    date: "2026年3月16日（月）",
    text: "『PEAK END』 劇場公開決定 Image Forum、出町座 他",
  },
];
---

<!-- iPhone 16 - news -->
<div class="bg-[#ffffeb] relative size-full">
  <div class="max-w-120 mx-auto absolute content-stretch flex flex-col gap-[16px] items-center left-[20px] top-[66px] w-[353px]">

    <!-- 上部区切り線 -->
    <div class="h-0 relative w-full">
      <div class="absolute inset-[-1px_0_0_0]">
        {imgLine11 && <img alt="" class="block max-w-none size-full" src={imgLine11} />}
      </div>
    </div>

    <!-- ニュース一覧 -->
    <ul class="content-stretch flex flex-col items-start w-full list-none p-0 m-0">
      {newsItems.map((item) => (
        <li class="content-stretch flex flex-col items-end pb-[8px] w-full">
          <!-- 日付バッジ -->
          <div class="bg-[#deca37] content-stretch flex items-center justify-center mb-[-8px] px-[16px] py-[2px]">
            <p class="text-[12px] text-center whitespace-nowrap">{item.date}</p>
          </div>
          <!-- アイコン + リンクバッジ -->
          <div class="content-stretch flex gap-[2px] h-[54px] items-center mb-[-8px] w-full">
            <!-- SolaIcon -->
            <div class="relative size-[42px]">
              <img
                alt=""
                class="absolute inset-0 max-w-none object-cover pointer-events-none size-full"
                src={imgSolaIcon2}
              />
            </div>
            <!-- 吹き出し三角 + テキストバッジ -->
            <div class="grid-cols-[max-content] grid-rows-[max-content] inline-grid leading-[0] place-items-start">
              <!-- 三角矢印 -->
              <div
                class="col-1 flex h-[27.382px] items-center justify-center ml-0 mt-0 row-1 w-[29.753px]"
                style="--transform-inner-width: 0; --transform-inner-height: 0"
              >
                <div class="flex-none rotate-[-52.26deg]">
                  <div class="h-[27px] relative w-[13.727px]">
                    <div class="absolute bottom-1/4 left-[6.7%] right-[6.7%] top-0">
                      {imgPolygon3 && <img alt="" class="block max-w-none size-full" src={imgPolygon3} />}
                    </div>
                  </div>
                </div>
              </div>
              <!-- テキストバッジ -->
              <a
                href="#"
                class="bg-[#deca37] col-1 content-stretch flex items-center justify-center max-w-[297px] ml-[10.59px] mt-[8px] px-[15px] py-[10px] rounded-[50px] row-1 w-[209px] no-underline"
              >
                <p class="decoration-solid flex-[1_0_0] min-h-px min-w-px text-[11px] underline">{item.text}</p>
              </a>
            </div>
          </div>
        </li>
      ))}
    </ul>

    <!-- 下部区切り線 -->
    <div class="h-0 relative w-full">
      <div class="absolute inset-[-1px_0_0_0]">
        {imgLine11 && <img alt="" class="block max-w-none size-full" src={imgLine11} />}
      </div>
    </div>

  </div>

  <!-- セクション見出し "# news" -->
  <div class="-translate-x-1/2 absolute bg-[var(--heading,#fefefe)] content-stretch flex items-center justify-center left-1/2 px-[18px] py-[12px] top-[13px]">
    <div class="flex flex-col justify-center leading-[0] text-[12px] text-center whitespace-nowrap">
      <p class="leading-[77.45000457763672%]"># news</p>
    </div>
  </div>

  <!-- "and more..." ボタン -->
  <a
    href="#news-list"
    class="-translate-x-1/2 absolute bg-[var(--keycolor,#deca37)] content-stretch flex items-center justify-center left-[calc(50%+0.5px)] px-[4px] py-[5px] top-[342px] no-underline"
  >
    <div class="flex flex-col justify-center leading-[0] text-[12px] text-center whitespace-nowrap">
      <p class="leading-[77.45000457763672%] mb-0">+ and more...</p>
      <p class="leading-[77.45000457763672%]">→</p>
    </div>
  </a>

</div>
