---
// Vector blob SVGs (correct Figma exports)
const imgVectorBlob  = "/images/Vector_blob.svg";   // fig1/2/3: 316×278 viewBox, overflow:visible
const imgVectorBlob4 = "/images/Vector_blob4.svg";  // fig4: 377×346 viewBox, overflow:visible
const imgFig4 = "/images/92330cc46d5c502af0d668622847cee81798d739.svg";
const imgFig5 = "/images/0dfaa0b9c774380cb6918660fdb0ea313201e7e3.svg";
const img2025 = "/images/6e554baa43145b74ead445637cf82be6420ae26c.svg";
const img21 = "/images/125dc54aa81e4c9fb336eb85c4203adaca81da8b.svg";
const img7 = "/images/c8287f86f8184cce80470ffa9acc2153365b64f5.svg";
const img4niceNice = "/images/d3a144be8071810513867f3d9714da4aa0e618bb.svg";
const imgBgYellow3 = "/images/212630414cccffaef9fc8502c1f0be4f6baf88b3.png";
const imgSolaRinOnly1 = "/images/46606872d0102130d41314be65d8134db2ded4c4.png";
const imgTitlePeak1 = "/images/08fb774dc9063c905a76f3aeaf327e2b32a6b00b.png";
const imgTitleEnd1 = "/images/883f4bc5986499fce38c4210f4172809136aed9c.png";
const img1 = "/images/f09c6c8c8f4b8d0253133d85fbf5d3051cc6c91e.png";
const img2 = "/images/9d073d64e7688e630e0dd109d07cc14f1dc79d01.png";
// Figma PNG exports (transparency already baked-in)
const imgMaskGroupL = "/images/Mask groupL.png";
const imgMaskGroupC = "/images/Mask groupC.png";
const imgMaskGroupR = "/images/Mask groupR.png";
// Pre-masked transparent PNGs (organic blob shape baked in from Figma export)
const imgTc30512mask = "/images/tc003051 1_mask.png";
const imgTc30422mask = "/images/tc003042 1_mask.png";
---
<div class="bg-[#ffffeb] relative w-full h-[2786px] overflow-hidden">

  <!-- Yellow background (863px height per Figma) -->
  <div class="absolute h-[863px] left-0 top-0 w-full overflow-hidden">
    <div class="absolute inset-0 pointer-events-none">
      <img alt="" class="absolute h-[168.27%] left-[-80.58%] max-w-none top-0 w-[261.17%]" src={imgBgYellow3}/>
    </div>
  </div>

  <!-- Blob masked photos: 3× 393×247px PNGs stacked at same position -->
  <!-- Each PNG has transparency baked-in from Figma export           -->
  <div class="absolute pointer-events-none" style="left: 0; top: 803px; width: 393px; height: 247px;">
    <img alt="" src={imgMaskGroupL} style="display:block; width: 393px; height: 247px;"/>
  </div>
  <div class="absolute pointer-events-none" style="left: 0; top: 803px; width: 393px; height: 247px;">
    <img alt="" src={imgMaskGroupC} style="display:block; width: 393px; height: 247px;"/>
  </div>
  <div class="absolute pointer-events-none" style="left: 0; top: 803px; width: 393px; height: 247px;">
    <img alt="" src={imgMaskGroupR} style="display:block; width: 393px; height: 247px;"/>
  </div>

  <!-- "A Film by SHIN CHAERIN" -->
  <p class="absolute h-[29px] left-[calc(50%-91.5px)] text-[16px] text-white top-[815px] w-[183px]">A Film by SHIN CHAERIN</p>

  <!-- Hero photo: SolaRin -->
  <div class="absolute h-[506px] left-[17px] top-[104px] w-[362px]">
    <img alt="" class="absolute inset-0 max-w-none object-cover pointer-events-none size-full" src={imgSolaRinOnly1}/>
  </div>

  <!-- Title: PEAK -->
  <div class="absolute h-[228px] left-[-14px] top-[394px] w-[358px]">
    <img alt="" class="absolute inset-0 max-w-none object-cover pointer-events-none size-full" src={imgTitlePeak1}/>
  </div>
  <!-- Title: END -->
  <div class="absolute h-[206px] left-[108px] top-[561px] w-[323px]">
    <img alt="" class="absolute inset-0 max-w-none object-cover pointer-events-none size-full" src={imgTitleEnd1}/>
  </div>

  <!-- fig 1: yellow blob + 「空の広さくらい」(left side) -->
  <!-- display:contents makes children position relative to the main .relative container -->
  <div class="contents">
    <div class="absolute flex inset-[34.13%_29.64%_50.78%_-36.64%] items-center justify-center pointer-events-none" data-vec="b1">
      <div class="flex-none h-[278.256px] rotate-[135.02deg] skew-x-[0.03deg] w-[316.288px]">
        <div class="relative size-full">
          <img alt="" class="absolute block max-w-none size-full" src={imgVectorBlob}/>
        </div>
      </div>
    </div>
    <div class="absolute font-['Zen_Kaku_Gothic_New',sans-serif] font-medium leading-[0] text-[16px] [text-shadow:0px_4px_4px_rgba(0,0,0,0.25)] text-white" style="left: calc(50% - 179.5px); top: 1051px; width: 259px;" data-vec="t1">
      <p class="leading-normal mb-0">空の広さくらい</p>
      <p class="leading-normal">地面の広さくらい</p>
    </div>
  </div>

  <!-- fig 2: yellow blob + 「하늘만큼」(right side) -->
  <div class="contents">
    <div class="absolute flex inset-[33.6%_-52.66%_51.35%_45.55%] items-center justify-center pointer-events-none" data-vec="b2">
      <div class="flex-none h-[278.256px] rotate-[-136.94deg] skew-x-[0.03deg] w-[316.288px]">
        <div class="relative size-full">
          <img alt="" class="absolute block max-w-none size-full" src={imgVectorBlob}/>
        </div>
      </div>
    </div>
    <div class="absolute font-['Noto_Sans_KR',sans-serif] font-normal leading-[0] text-[16px] text-right [text-shadow:0px_4px_4px_rgba(0,0,0,0.25)] text-white" style="left: calc(50% + 180.5px); top: 1075px; width: 89px; transform: translateX(-100%);" data-vec="t2" data-vec-base="translateX(-100%)">
      <p class="leading-normal mb-0">하늘만큼</p>
      <p class="leading-normal">땅만큼</p>
    </div>
  </div>

  <!-- Main film still (full width) -->
  <div class="absolute h-[214px] left-0 top-[1146px] w-[394px]">
    <img alt="" class="absolute inset-0 max-w-none object-cover pointer-events-none size-full" src={img1}/>
  </div>

  <!-- Caption -->
  <p class="-translate-x-1/2 absolute h-[38px] left-1/2 text-[16px] text-center text-white [text-shadow:0px_4px_4px_rgba(0,0,0,0.25)] top-[1328px] w-[319px]">そらと一緒にいると自由になる気がする。</p>

  <!-- Sub photos 2x2 -->
  <div class="absolute h-[131px] left-[-2px] top-[1360px] w-[241px]"><img alt="" class="absolute inset-0 max-w-none object-cover pointer-events-none size-full" src={img2}/></div>
  <div class="absolute h-[131px] left-[-2px] top-[1490px] w-[241px]"><img alt="" class="absolute inset-0 max-w-none object-cover pointer-events-none size-full" src={img2}/></div>
  <div class="absolute h-[131px] left-[238px] top-[1360px] w-[241px]"><img alt="" class="absolute inset-0 max-w-none object-cover pointer-events-none size-full" src={img2}/></div>
  <div class="absolute h-[131px] left-[239px] top-[1490px] w-[241px]"><img alt="" class="absolute inset-0 max-w-none object-cover pointer-events-none size-full" src={img2}/></div>

  <!-- ================================================================
       Render order (bottom→top) matching Figma layer order:
       1. tc_003042 (bottom)
       2. fig 4 (yellow blob + text, left)
       3. tc003051 (rendered ON TOP of fig 4)
       4. fig 3 (top, right side)
       ================================================================ -->

  <!-- 1. tc_003042: blob photo RIGHT side — transparent PNG, left=81, top=1877 -->
  <!-- PNG represents Figma mask group (x=81, w=312), blob content at PNG right portion -->
  <div class="absolute pointer-events-none" style="left: 81px; top: 1877px;">
    <img alt="" src={imgTc30422mask} style="display:block; width: 312px; height: 491px;"/>
  </div>

  <!-- 2. fig 4: large yellow blob + 「そらといると」(left side, y=1866) -->
  <div class="contents">
    <div class="absolute flex items-center justify-center pointer-events-none" style="left: -168px; top: 1866px; width: 508px; height: 511.995px;" data-vec="b4">
      <div class="flex-none rotate-[-50.16deg]">
        <div class="h-[346.376px] relative w-[377.802px]">
          <img alt="" class="absolute block max-w-none size-full" src={imgVectorBlob4}/>
        </div>
      </div>
    </div>
    <div class="absolute flex inset-[74.66%_38.84%_21.05%_8.4%] items-center justify-center" data-vec="t4">
      <div class="flex-none h-[117.901px] rotate-[0.44deg] skew-x-[0.88deg] w-[206.444px]">
        <div class="font-['Zen_Kaku_Gothic_New',sans-serif] font-medium leading-[0] relative size-full text-[16px] text-white [text-shadow:0px_4px_4px_rgba(0,0,0,0.25)]">
          <p class="leading-normal mb-0">そらといると</p>
          <p class="leading-normal mb-0">何かが愛に変わる</p>
          <p class="leading-normal">瞬間が沢山ある。</p>
        </div>
      </div>
    </div>
  </div>

  <!-- 3. tc003051: blob photo LEFT side — transparent PNG, left=0, top=1591 -->
  <!-- PNG (312×470) = visible portion of Figma mask group (which starts at x=-153) -->
  <!-- Blob content sits at PNG x≈24-184, so left=0 places it at page x≈24-184 (left side) -->
  <div class="absolute pointer-events-none" style="left: 0px; top: 1591px;">
    <img alt="" src={imgTc30512mask} style="display:block; width: 312px; height: 470px;"/>
  </div>

  <!-- 4. fig 3: yellow blob + 「別の世界で」(right side, y=1487, top-most of group) -->
  <div class="contents">
    <div class="absolute flex inset-[53.39%_-33.47%_31.53%_26.46%] items-center justify-center pointer-events-none" data-vec="b3">
      <div class="flex-none h-[278.256px] rotate-[135.02deg] skew-x-[0.03deg] w-[316.288px]">
        <div class="relative size-full">
          <img alt="" class="absolute block max-w-none size-full" src={imgVectorBlob}/>
        </div>
      </div>
    </div>
    <div class="absolute font-['Zen_Kaku_Gothic_New',sans-serif] font-medium leading-[0] text-[16px] [text-shadow:0px_4px_4px_rgba(0,0,0,0.25)] text-white" style="top: 59.34%; right: -4.33%; bottom: 37%; left: 59.03%;" data-vec="t3">
      <p class="leading-normal mb-0">別の世界で</p>
      <p class="leading-normal mb-0">別の存在として</p>
      <p class="leading-normal mb-0">生きてきた私たちが</p>
      <p class="leading-normal">お互いを感じる瞬間。</p>
    </div>
  </div>

  <!-- Decorative figures -->
  <div class="absolute left-[89px] size-[225px] top-[2301px]">
    <img alt="" class="absolute block max-w-none size-full" src={imgFig4}/>
  </div>
  <div class="absolute left-[131px] size-[141px] top-[2539px]">
    <img alt="" class="absolute block max-w-none size-full" src={imgFig5}/>
  </div>

  <!-- Vector blob scroll-scale animation -->
  <script>
    (function () {
      const SCALE    = 1.08;
      const DUR_IN   = '0.32s';
      const DUR_OUT  = '0.55s';
      const EASE     = 'cubic-bezier(0.25, 0.46, 0.45, 0.94)';
      const canHover = window.matchMedia('(hover: hover) and (pointer: fine)').matches;

      function els(...keys) {
        return keys.map(k => document.querySelector(`[data-vec="${k}"]`)).filter(Boolean);
      }

      // ── Competitive groups (nearest one wins) ──────────────────
      // fig1+fig2 share the same zone and animate together.
      const compGroups = [
        { id: 0, members: els('b1','t1','b2','t2') },
        { id: 1, members: els('b3','t3') },
        { id: 2, members: els('b4','t4') },
      ].filter(g => g.members.length > 0);

      // ── Independent groups (non-exclusive, viewport-based) ─────
      const indepGroups = [];

      const byId = {};
      [...compGroups, ...indepGroups].forEach(g => {
        byId[g.id] = g;
        g.members.forEach(el => { el.style.willChange = 'transform'; });
      });

      const compTimers  = {};
      const indepTimers = {};
      let activeCompId  = -1;

      function setScale(el, scale) {
        el.style.transition = `transform ${scale > 1 ? DUR_IN : DUR_OUT} ${EASE}`;
        const base = el.dataset.vecBase ? el.dataset.vecBase + ' ' : '';
        el.style.transform = scale === 1 ? (el.dataset.vecBase || '') : `${base}scale(${scale})`;
      }
      function scaleGroup(g, scale) { g.members.forEach(el => setScale(el, scale)); }

      // Shortest distance from point to rect (0 if inside)
      function ptRectDist(cx, cy, r) {
        return Math.hypot(Math.max(r.left - cx, 0, cx - r.right),
                          Math.max(r.top  - cy, 0, cy - r.bottom));
      }

      function nearestComp(cx, cy) {
        let best = null, bestDist = Infinity;
        compGroups.forEach(g => g.members.forEach(el => {
          const d = ptRectDist(cx, cy, el.getBoundingClientRect());
          if (d < bestDist) { bestDist = d; best = g; }
        }));
        return best;
      }

      function activateComp(g) {
        if (activeCompId !== -1 && activeCompId !== g.id) {
          clearTimeout(compTimers[activeCompId]);
          delete compTimers[activeCompId];
          scaleGroup(byId[activeCompId], 1);
        }
        activeCompId = g.id;
        scaleGroup(g, SCALE);
        clearTimeout(compTimers[g.id]);
        compTimers[g.id] = setTimeout(() => {
          scaleGroup(g, 1);
          if (activeCompId === g.id) activeCompId = -1;
          delete compTimers[g.id];
        }, 180);
      }

      // Non-exclusive: fires independently whenever element is in viewport
      function activateIndep(g) {
        scaleGroup(g, SCALE);
        clearTimeout(indepTimers[g.id]);
        indepTimers[g.id] = setTimeout(() => {
          scaleGroup(g, 1);
          delete indepTimers[g.id];
        }, 180);
      }

      function checkIndep() {
        indepGroups.forEach(g => {
          const inView = g.members.some(el => {
            const r = el.getBoundingClientRect();
            return r.top < window.innerHeight && r.bottom > 0;
          });
          if (inView) activateIndep(g);
        });
      }

      // ── Touch drag ──────────────────────────────────────────────
      let touchStartY = 0, touchCurX = 0, touchCurY = 0, isDragging = false;

      window.addEventListener('touchstart', e => {
        touchStartY = e.touches[0].clientY;
        touchCurX   = e.touches[0].clientX;
        touchCurY   = e.touches[0].clientY;
        isDragging  = false;
      }, { passive: true });

      window.addEventListener('touchmove', e => {
        touchCurX = e.touches[0].clientX;
        touchCurY = e.touches[0].clientY;
        if (!isDragging && Math.abs(touchCurY - touchStartY) > 4) isDragging = true;
        if (isDragging) {
          const g = nearestComp(touchCurX, touchCurY);
          if (g) activateComp(g);
          checkIndep();
        }
      }, { passive: true });

      window.addEventListener('touchend', () => {
        if (isDragging) {
          if (activeCompId !== -1) {
            const gid = activeCompId;
            clearTimeout(compTimers[gid]);
            compTimers[gid] = setTimeout(() => {
              scaleGroup(byId[gid], 1);
              if (activeCompId === gid) activeCompId = -1;
              delete compTimers[gid];
            }, 200);
          }
          indepGroups.forEach(g => {
            if (g.id in indepTimers) {
              clearTimeout(indepTimers[g.id]);
              indepTimers[g.id] = setTimeout(() => {
                scaleGroup(g, 1);
                delete indepTimers[g.id];
              }, 200);
            }
          });
        }
        isDragging = false;
      }, { passive: true });

      // ── Mouse wheel / keyboard scroll ────────────────────────────
      window.addEventListener('scroll', () => {
        const g = nearestComp(window.innerWidth / 2, window.innerHeight / 2);
        if (g) activateComp(g);
        checkIndep();
      }, { passive: true });

      // ── Desktop hover ─────────────────────────────────────────────
      if (canHover) {
        // Competitive groups: hover on text elements (have pointer events)
        compGroups.forEach(g => {
          g.members.filter(el => !el.classList.contains('pointer-events-none')).forEach(el => {
            el.addEventListener('mouseenter', () => {
              clearTimeout(compTimers[g.id]);
              delete compTimers[g.id];
              if (activeCompId !== -1 && activeCompId !== g.id) {
                scaleGroup(byId[activeCompId], 1);
                activeCompId = -1;
              }
              scaleGroup(g, SCALE);
            });
            el.addEventListener('mouseleave', () => {
              scaleGroup(g, 1);
              if (activeCompId === g.id) activeCompId = -1;
            });
          });
        });
        // Independent groups: hover on container directly (no pointer-events-none)
        indepGroups.forEach(g => {
          g.members.forEach(el => {
            el.addEventListener('mouseenter', () => {
              clearTimeout(indepTimers[g.id]);
              delete indepTimers[g.id];
              scaleGroup(g, SCALE);
            });
            el.addEventListener('mouseleave', () => {
              scaleGroup(g, 1);
            });
          });
        });
      }
    })();
  </script>

  <!-- Bottom text "ある愛はこういう風に始まった。" -->
  <div class="-translate-x-1/2 absolute flex items-center justify-center left-[calc(50%+12.53px)] top-[97.18%] w-[246.057px]">
    <div class="flex-none h-[35.559px] rotate-[0.44deg] skew-x-[0.88deg] w-[245.79px]">
      <p class="font-['Zen_Kaku_Gothic_New',sans-serif] font-medium leading-[normal] relative size-full text-[16px] text-[#deca37] text-center">ある愛はこういう風に始まった。</p>
    </div>
  </div>
  <div class="-translate-x-1/2 absolute flex items-center justify-center left-[calc(50%-68.33px)] top-[96.82%] w-[36.345px]">
    <div class="flex-none h-[14.578px] w-[36.233px]">
      <p class="font-['Zen_Kaku_Gothic_New',sans-serif] font-medium leading-[normal] relative size-full text-[10px] text-[#deca37] text-center">えいが</p>
    </div>
  </div>

  <!-- Award signs -->
  <div class="-translate-x-1/2 absolute flex gap-[4px] items-center left-[calc(50%-0.17px)] top-[752px]">
    <div class="h-[48.903px] relative shrink-0 w-[81.844px]"><img alt="" class="absolute block max-w-none size-full" src={img2025}/></div>
    <div class="h-[48.903px] relative shrink-0 w-[81.844px]"><img alt="" class="absolute block max-w-none size-full" src={img21}/></div>
    <div class="h-[48.903px] relative shrink-0 w-[90.978px]"><img alt="" class="absolute block max-w-none size-full" src={img7}/></div>
    <div class="h-[48.903px] relative shrink-0 w-[81.999px]"><img alt="" class="absolute block max-w-none size-full" src={img4niceNice}/></div>
  </div>

</div>
