---
// 上映劇場は src/data/theaters.json で管理（TinaCMSの /admin から編集可能）
import theaters from "../../data/theaters.json";

const base = import.meta.env.BASE_URL;
const imgTable = base + "images/ab2ba9388f55027d4323199d2bb8617722e4992d.png";

const rows = theaters.items as { region: string; name: string; date: string; url?: string }[];
---

<div class="bg-[#ffffeb] relative w-full overflow-hidden">

  <!-- THEATERS タイトル（ティッカー） -->
  <div class="relative w-full h-[52px]">
    <div class="absolute content-stretch flex flex-col gap-[10px] h-[38px] items-start left-[18px] py-[6px] top-[7px] w-[384px]" style="overflow: hidden;">
      <div class="absolute bg-[rgba(217,107,157,0.6)] h-[25px] w-[258px]" style="left: 126px; top: 6px;"></div>
      <div class="absolute content-stretch flex gap-[6px] items-end leading-[normal] left-0 not-italic text-[#deca37] top-0 whitespace-nowrap">
        <p class="font-['Londrina_Solid',sans-serif] relative shrink-0 text-[32px]">THEATERS</p>
        <div class="overflow-hidden flex-1 relative">
          <div class="animate-ticker relative shrink-0 text-[24px] py-[2px]">
            <div class="content-stretch flex gap-[6px] items-center pr-[6px]">
              <p class="font-['Londrina_Solid',sans-serif] font-light relative shrink-0">THEATERS</p>
              <p class="font-['Londrina_Solid',sans-serif] font-[100] relative shrink-0">THEATERS</p>
              <p class="font-['Londrina_Solid',sans-serif] font-black relative shrink-0">THEATERS</p>
              <p class="font-['Londrina_Solid',sans-serif] relative shrink-0">THEATERS</p>
              <p class="font-['Londrina_Solid',sans-serif] font-light relative shrink-0">THEATERS</p>
              <p class="font-['Londrina_Solid',sans-serif] font-[100] relative shrink-0">THEATERS</p>
              <p class="font-['Londrina_Solid',sans-serif] font-black relative shrink-0">THEATERS</p>
              <p class="font-['Londrina_Solid',sans-serif] relative shrink-0">THEATERS</p>
            </div>
            <div class="content-stretch flex gap-[6px] items-center pr-[6px]" aria-hidden="true">
              <p class="font-['Londrina_Solid',sans-serif] font-light relative shrink-0">THEATERS</p>
              <p class="font-['Londrina_Solid',sans-serif] font-[100] relative shrink-0">THEATERS</p>
              <p class="font-['Londrina_Solid',sans-serif] font-black relative shrink-0">THEATERS</p>
              <p class="font-['Londrina_Solid',sans-serif] relative shrink-0">THEATERS</p>
              <p class="font-['Londrina_Solid',sans-serif] font-light relative shrink-0">THEATERS</p>
              <p class="font-['Londrina_Solid',sans-serif] font-[100] relative shrink-0">THEATERS</p>
              <p class="font-['Londrina_Solid',sans-serif] font-black relative shrink-0">THEATERS</p>
              <p class="font-['Londrina_Solid',sans-serif] relative shrink-0">THEATERS</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- 上映劇場テーブル（高さは行数に応じて可変） -->
  <div class="relative w-full pt-[24px] pb-[56px]">

    <!-- 背景画像: タイル状に繰り返し（repeat-y）、はみ出しは外側 overflow-hidden でトリミング -->
    <div
      class="absolute inset-0 opacity-87 pointer-events-none"
      style={`background-image:url('${imgTable}'); background-repeat:repeat-y; background-size:100% auto; background-position:55% top; filter:grayscale(1) brightness(0.4);`}
    ></div>

    <!-- 行 -->
    <div class="relative flex flex-col gap-[12px] items-center w-full">

      <!-- ヘッダー行 -->
      <div class="content-stretch flex flex-col gap-[12px] items-center relative shrink-0 w-full">
        <div class="content-stretch flex font-['Shippori_Antique_B1',sans-serif] items-center justify-between not-italic relative shrink-0 text-[14px] text-shadow-[0px_4px_4px_rgba(0,0,0,0.25)] text-white w-[370px]">
          <div class="flex flex-col justify-center leading-[0] relative shrink-0 text-center w-[60px]">
            <p class="leading-[normal]">地域</p>
          </div>
          <p class="leading-[normal] relative shrink-0 flex-1 px-2">劇場名</p>
          <p class="leading-[normal] relative shrink-0 w-[80px] text-left">公開日</p>
        </div>
        <div class="flex items-center justify-center relative shrink-0 w-[370px] mx-auto mt-[6px]">
          <div class="w-full border-t-[0.5px] border-white opacity-50"></div>
        </div>
      </div>

      <!-- データ行 -->
      {rows.map((t) => (
        <div class="content-stretch flex flex-col gap-[12px] items-center relative shrink-0 w-full">
          <div class="content-stretch flex font-['Shippori_Antique_B1',sans-serif] items-center justify-between not-italic relative shrink-0 text-[14px] text-shadow-[0px_4px_4px_rgba(0,0,0,0.25)] text-white w-[370px]">
            <div class="flex flex-col justify-center leading-[0] relative shrink-0 text-center w-[60px]">
              <p class="leading-[normal]">{t.region}</p>
            </div>
            <p class="leading-[normal] relative shrink-0 flex-1 px-2">
              {t.url && t.url.trim()
                ? <a href={t.url} target="_blank" rel="noopener noreferrer" class="underline decoration-1 underline-offset-2 hover:opacity-70 transition-opacity">{t.name}</a>
                : t.name}
            </p>
            <p class="leading-[normal] relative shrink-0 w-[80px] text-left">{t.date}</p>
          </div>
          <div class="flex items-center justify-center relative shrink-0 w-[370px] mx-auto mt-[6px]">
            <div class="w-full border-t-[0.5px] border-white opacity-50"></div>
          </div>
        </div>
      ))}

    </div>
  </div>
</div>
