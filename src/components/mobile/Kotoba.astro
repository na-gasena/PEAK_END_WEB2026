<script>
  (function () {
    const el = document.getElementById('kotoba-scroll');
    if (!el) return;

    // ── 初期スクロール: 中央列（col2）を画面中央に表示 ──
    // pl=18px, col=313px, gap=15px → col2 left=346px, col2 center≈503px
    // scrollLeft = col2_center - viewport/2 = 503 - 393/2 ≈ 306
    el.scrollLeft = 306;

    // ── ドラッグスクロール（マウス） ──
    let isDown = false;
    let startX = 0;
    let scrollLeft = 0;
    let hasDragged = false;

    el.addEventListener('mousedown', (e) => {
      isDown = true;
      hasDragged = false;
      startX = e.pageX - el.getBoundingClientRect().left;
      scrollLeft = el.scrollLeft;
      el.style.cursor = 'grabbing';
      e.preventDefault();
    });

    window.addEventListener('mouseup', () => {
      if (!isDown) return;
      isDown = false;
      el.style.cursor = 'grab';
      if (hasDragged) {
        el.addEventListener('click', (e) => e.stopPropagation(), { capture: true, once: true });
      }
    });

    window.addEventListener('mousemove', (e) => {
      if (!isDown) return;
      const x = e.pageX - el.getBoundingClientRect().left;
      const walk = x - startX;
      if (Math.abs(walk) > 4) hasDragged = true;
      el.scrollLeft = scrollLeft - walk;
    });

    // ── カードスケールアニメーション（水平スクロール連動）──
    const CARD_SCALE   = 1.05;
    const CARD_DUR_IN  = '0.25s';
    const CARD_DUR_OUT = '0.42s';
    const CARD_EASE    = 'cubic-bezier(0.25, 0.46, 0.45, 0.94)';

    const cards = /** @type {HTMLElement[]} */ ([...el.querySelectorAll('[data-kotoba-card]')]);
    cards.forEach(c => { c.style.willChange = 'transform'; });

    // offsetLeft が同じカードを同列としてグループ化
    const colMap = new Map();
    cards.forEach(c => {
      const key = c.offsetLeft;
      if (!colMap.has(key)) colMap.set(key, []);
      colMap.get(key).push(c);
    });
    const columns = [...colMap.entries()]
      .sort(([a], [b]) => a - b)
      .map(([left, cds]) => ({ cds, cx: left + (cds[0].offsetWidth / 2) }));

    let activeCardGroup = /** @type {HTMLElement[]|null} */ (null);
    let cardTimer = /** @type {ReturnType<typeof setTimeout>|null} */ (null);

    function scaleCardGroup(cds, scale) {
      cds.forEach(c => {
        c.style.transition = `transform ${scale > 1 ? CARD_DUR_IN : CARD_DUR_OUT} ${CARD_EASE}`;
        c.style.transform  = scale === 1 ? '' : `scale(${scale})`;
      });
    }

    function onHScroll() {
      const cx = el.scrollLeft + el.clientWidth / 2;
      let nearest = columns[0], minD = Infinity;
      columns.forEach(col => {
        const d = Math.abs(col.cx - cx);
        if (d < minD) { minD = d; nearest = col; }
      });

      if (nearest.cds !== activeCardGroup) {
        if (activeCardGroup) scaleCardGroup(activeCardGroup, 1);
        activeCardGroup = nearest.cds;
      }
      scaleCardGroup(activeCardGroup, CARD_SCALE);

      clearTimeout(cardTimer);
      cardTimer = setTimeout(() => {
        if (activeCardGroup) { scaleCardGroup(activeCardGroup, 1); activeCardGroup = null; }
      }, 180);
    }

    // 水平スクロール（コンテナ内ドラッグ）
    el.addEventListener('scroll', onHScroll, { passive: true });

    // 縦スクロール（ページスクロール）でもkotobaが画面内にあれば発火
    window.addEventListener('scroll', () => {
      const r = el.getBoundingClientRect();
      if (r.top < window.innerHeight && r.bottom > 0) onHScroll();
    }, { passive: true });
  })();
</script>
