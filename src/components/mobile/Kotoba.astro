---
// コメントは src/data/kotoba.json で管理（TinaCMSの /admin から編集可能）
import { kotobaItems, paragraphs } from "../../lib/people";

const imgCamFilmBg1 = import.meta.env.BASE_URL + "images/b1749199e65e769802f6d3744bd5736514a8fb56.png";

// カードに出す抜粋（本文の最初の段落）
const cards = kotobaItems.map((k) => ({ ...k, excerpt: paragraphs(k.body)[0] ?? "" }));
---
<div class="bg-[#ffffeb] relative w-full overflow-hidden">

  <!-- Top spacing + Section Header area (高さを76pxに拡張して「敬称略、順不同」を収める) -->
  <div class="relative h-[76px]">
    <!-- Section Header KOTOBA -->
    <div class="absolute content-stretch flex flex-col gap-[10px] h-[38px] items-start left-[18px] py-[6px] top-[7px] w-[384px]" style="overflow: hidden;">
      <div class="absolute bg-[rgba(217,107,157,0.6)] h-[25px] w-[289px]" style="left: 95px; top: 6px;"></div>
      <div class="absolute content-stretch flex gap-[6px] items-end leading-[normal] left-0 not-italic text-[#deca37] top-0 whitespace-nowrap">
        <p class="font-['Londrina_Solid',sans-serif] relative shrink-0 text-[32px]">KOTOBA</p>
        <div class="overflow-hidden flex-1 relative">
          <div class="animate-ticker relative shrink-0 text-[24px] py-[2px]">
          <div class="content-stretch flex gap-[6px] items-center pr-[6px]">
            <p class="font-['Londrina_Solid',sans-serif] font-light relative shrink-0">KOTOBA</p>
            <p class="font-['Londrina_Solid',sans-serif] font-[100] relative shrink-0">KOTOBA</p>
            <p class="font-['Londrina_Solid',sans-serif] font-black relative shrink-0">KOTOBA</p>
            <p class="font-['Londrina_Solid',sans-serif] relative shrink-0">KOTOBA</p>
            <p class="font-['Londrina_Solid',sans-serif] font-light relative shrink-0">KOTOBA</p>
            <p class="font-['Londrina_Solid',sans-serif] font-[100] relative shrink-0">KOTOBA</p>
            <p class="font-['Londrina_Solid',sans-serif] font-black relative shrink-0">KOTOBA</p>
            <p class="font-['Londrina_Solid',sans-serif] relative shrink-0">KOTOBA</p>
          </div>
          <div class="content-stretch flex gap-[6px] items-center pr-[6px]" aria-hidden="true">
            <p class="font-['Londrina_Solid',sans-serif] font-light relative shrink-0">KOTOBA</p>
            <p class="font-['Londrina_Solid',sans-serif] font-[100] relative shrink-0">KOTOBA</p>
            <p class="font-['Londrina_Solid',sans-serif] font-black relative shrink-0">KOTOBA</p>
            <p class="font-['Londrina_Solid',sans-serif] relative shrink-0">KOTOBA</p>
            <p class="font-['Londrina_Solid',sans-serif] font-light relative shrink-0">KOTOBA</p>
            <p class="font-['Londrina_Solid',sans-serif] font-[100] relative shrink-0">KOTOBA</p>
            <p class="font-['Londrina_Solid',sans-serif] font-black relative shrink-0">KOTOBA</p>
            <p class="font-['Londrina_Solid',sans-serif] relative shrink-0">KOTOBA</p>
          </div>
          </div>
        </div>
      </div>
    </div>
    <!-- 敬称略、順不同 (ヘッダー内に収める) -->
    <p class="absolute font-[family-name:var(--mainfont,'Zen_Kaku_Gothic_New:Medium',sans-serif)] leading-[normal] left-[18px] not-italic text-[#deca37] text-[12px] top-[56px] w-[103px]">敬称略、順不同</p>
  </div>

  <!-- Horizontally scrollable COMMENTS CARD（縦3行・列方向に増えていく） -->
  <div id="kotoba-scroll" class="w-full overflow-x-auto" style="scrollbar-width:none; -ms-overflow-style:none; cursor:grab;">
    <div class="grid gap-x-[15px] gap-y-[24px] pl-[18px] pr-[18px] pb-[40px] pt-[4px]"
         style="grid-template-rows:repeat(3,176px); grid-auto-flow:column; grid-auto-columns:313px; width:max-content;">

      {cards.map((c, i) => (
        <div data-kotoba-card class="h-[176px] relative w-[313px] cursor-pointer group hover:brightness-110 active:opacity-70 transition-[filter,opacity] select-none" onclick={`window.openModal('modal-kotoba-${i}')`}>
          <div class="absolute h-[176px] left-0 rounded-[6px] shadow-[0px_4px_4px_0px_rgba(0,0,0,0.25)] top-0 w-[313px]">
            <img alt="" class="absolute inset-0 max-w-none object-cover pointer-events-none rounded-[6px] size-full" src={imgCamFilmBg1}/>
          </div>
          <div class="absolute top-[6px] right-[6px] bg-[#deca37] rounded-full size-[20px] flex items-center justify-center z-10 pointer-events-none group-hover:scale-125 transition-transform">
            <svg viewBox="0 0 12 12" class="size-[10px]" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M2 10 L10 2 M5 2 H10 V7" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <div class="absolute flex flex-col justify-between font-['Klee_One:SemiBold',sans-serif] items-end leading-[normal] left-[6px] not-italic text-black top-[52px] bottom-[4px] w-[302px]">
            <p class="relative flex-1 min-h-0 overflow-hidden text-[14px] w-full">"{c.excerpt}"</p>
            <p class="relative shrink-0 text-[12px] text-right w-full">{c.name}{c.role}</p>
          </div>
        </div>
      ))}

    </div>
  </div>

</div>

<script>
  (function () {
    const el = document.getElementById('kotoba-scroll');
    if (!el) return;

    // ── 初期スクロール: 中央列（col2）を画面中央に表示 ──
    // pl=18px, col=313px, gap=15px → col2 left=346px, col2 center≈503px
    // scrollLeft = col2_center - viewport/2 = 503 - 393/2 ≈ 306
    el.scrollLeft = 306;

    // ── ドラッグスクロール（マウス） ──
    let isDown = false;
    let startX = 0;
    let scrollLeft = 0;
    let hasDragged = false;

    el.addEventListener('mousedown', (e) => {
      isDown = true;
      hasDragged = false;
      startX = e.pageX - el.getBoundingClientRect().left;
      scrollLeft = el.scrollLeft;
      el.style.cursor = 'grabbing';
      e.preventDefault();
    });

    window.addEventListener('mouseup', () => {
      if (!isDown) return;
      isDown = false;
      el.style.cursor = 'grab';
      if (hasDragged) {
        el.addEventListener('click', (e) => e.stopPropagation(), { capture: true, once: true });
      }
    });

    window.addEventListener('mousemove', (e) => {
      if (!isDown) return;
      const x = e.pageX - el.getBoundingClientRect().left;
      const walk = x - startX;
      if (Math.abs(walk) > 4) hasDragged = true;
      el.scrollLeft = scrollLeft - walk;
    });

    // ── カードスケールアニメーション（水平スクロール連動）──
    const CARD_SCALE   = 1.05;
    const CARD_DUR_IN  = '0.25s';
    const CARD_DUR_OUT = '0.42s';
    const CARD_EASE    = 'cubic-bezier(0.25, 0.46, 0.45, 0.94)';

    const cards = /** @type {HTMLElement[]} */ ([...el.querySelectorAll('[data-kotoba-card]')]);
    cards.forEach(c => { c.style.willChange = 'transform'; });

    // offsetLeft が同じカードを同列としてグループ化
    const colMap = new Map();
    cards.forEach(c => {
      const key = c.offsetLeft;
      if (!colMap.has(key)) colMap.set(key, []);
      colMap.get(key).push(c);
    });
    const columns = [...colMap.entries()]
      .sort(([a], [b]) => a - b)
      .map(([left, cds]) => ({ cds, cx: left + (cds[0].offsetWidth / 2) }));

    let activeCardGroup = /** @type {HTMLElement[]|null} */ (null);
    let cardTimer = /** @type {ReturnType<typeof setTimeout>|null} */ (null);

    function scaleCardGroup(cds, scale) {
      cds.forEach(c => {
        c.style.transition = `transform ${scale > 1 ? CARD_DUR_IN : CARD_DUR_OUT} ${CARD_EASE}`;
        c.style.transform  = scale === 1 ? '' : `scale(${scale})`;
      });
    }

    function onHScroll() {
      const cx = el.scrollLeft + el.clientWidth / 2;
      let nearest = columns[0], minD = Infinity;
      columns.forEach(col => {
        const d = Math.abs(col.cx - cx);
        if (d < minD) { minD = d; nearest = col; }
      });

      if (nearest.cds !== activeCardGroup) {
        if (activeCardGroup) scaleCardGroup(activeCardGroup, 1);
        activeCardGroup = nearest.cds;
      }
      scaleCardGroup(activeCardGroup, CARD_SCALE);

      clearTimeout(cardTimer);
      cardTimer = setTimeout(() => {
        if (activeCardGroup) { scaleCardGroup(activeCardGroup, 1); activeCardGroup = null; }
      }, 180);
    }

    // 水平スクロール（コンテナ内ドラッグ）
    el.addEventListener('scroll', onHScroll, { passive: true });

    // 縦スクロール（ページスクロール）でもkotobaが画面内にあれば発火
    window.addEventListener('scroll', () => {
      const r = el.getBoundingClientRect();
      if (r.top < window.innerHeight && r.bottom > 0) onHScroll();
    }, { passive: true });
  })();
</script>
