---
const imgImage12      = import.meta.env.BASE_URL + "images/da2e3b8d96025edbb33affa296eb5d667d8a079b.png";
const imgComIdSu2WtCoW02 = import.meta.env.BASE_URL + "images/47bef2b53c17056bf9ebfa528565751c89d25c97.png";
const imgComIdSu2WtCoW3  = import.meta.env.BASE_URL + "images/2a0b7e2c7705210f73b183afb4b434421405f796.png";
const imgComIdSu2WtCoW4  = import.meta.env.BASE_URL + "images/a6132af911c4122aef1a63bc26bbcba558c598fb.png";
const imgComIdSu2WtCoW5  = import.meta.env.BASE_URL + "images/8d3db474c1a814f8701e89992609a2c3b56bee61.png";

const icons = [
  { href: "https://eiga.com/movie/105830/",           src: imgComIdSu2WtCoW02, label: "映画.com" },
  { href: "https://x.com/PEAK_END_",                  src: imgComIdSu2WtCoW3,  label: "X (Twitter)" },
  { href: "https://www.instagram.com/peak__end__/",   src: imgComIdSu2WtCoW4,  label: "Instagram" },
  { href: "https://filmarks.com/movies/123647",       src: imgComIdSu2WtCoW5,  label: "Filmarks" },
];
---

<div class="bg-[#ffffeb] relative size-full h-[391px] overflow-hidden">

  <!-- Section header -->
  <div class="absolute content-stretch flex flex-col gap-[10px] h-[38px] items-start left-[18px] py-[6px] top-[7px] w-[382px]" style="overflow: hidden;">
    <div class="absolute bg-[rgba(217,107,157,0.6)] h-[25px] w-[329px]" style="left: 53px; top: 6px;"></div>
    <div class="absolute content-stretch flex gap-[6px] items-end leading-[normal] left-0 not-italic text-[#deca37] top-0 whitespace-nowrap">
      <p class="font-['Londrina_Solid',sans-serif] relative shrink-0 text-[32px]">SNS</p>
      <div class="overflow-hidden flex-1 relative">
        <div class="animate-ticker relative shrink-0 text-[24px] py-[2px]">
          <div class="content-stretch flex gap-[6px] items-center pr-[6px]">
            <p class="font-['Londrina_Solid',sans-serif] font-light relative shrink-0">SNS</p>
            <p class="font-['Londrina_Solid',sans-serif] font-[100] relative shrink-0">SNS</p>
            <p class="font-['Londrina_Solid',sans-serif] font-black relative shrink-0">SNS</p>
            <p class="font-['Londrina_Solid',sans-serif] relative shrink-0">SNS</p>
            <p class="font-['Londrina_Solid',sans-serif] font-light relative shrink-0">SNS</p>
            <p class="font-['Londrina_Solid',sans-serif] font-[100] relative shrink-0">SNS</p>
            <p class="font-['Londrina_Solid',sans-serif] font-black relative shrink-0">SNS</p>
            <p class="font-['Londrina_Solid',sans-serif] relative shrink-0">SNS</p>
          </div>
          <div class="content-stretch flex gap-[6px] items-center pr-[6px]" aria-hidden="true">
            <p class="font-['Londrina_Solid',sans-serif] font-light relative shrink-0">SNS</p>
            <p class="font-['Londrina_Solid',sans-serif] font-[100] relative shrink-0">SNS</p>
            <p class="font-['Londrina_Solid',sans-serif] font-black relative shrink-0">SNS</p>
            <p class="font-['Londrina_Solid',sans-serif] relative shrink-0">SNS</p>
            <p class="font-['Londrina_Solid',sans-serif] font-light relative shrink-0">SNS</p>
            <p class="font-['Londrina_Solid',sans-serif] font-[100] relative shrink-0">SNS</p>
            <p class="font-['Londrina_Solid',sans-serif] font-black relative shrink-0">SNS</p>
            <p class="font-['Londrina_Solid',sans-serif] relative shrink-0">SNS</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- SNS icon links -->
  <div class="-translate-x-1/2 absolute content-stretch flex items-center left-[calc(50%+0.5px)] top-[87px]">
    {icons.map(({ href, src, label }) => (
      <a
        class="content-stretch flex gap-[10px] items-center p-[34px] relative shrink-0 size-[99px] group hover:bg-[#deca37]/20 active:bg-[#deca37]/50 transition-colors"
        href={href}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={label}
      >
        <!-- Decorative border frames -->
        <div class="absolute contents left-[-0.03px] top-0">
          <div class="absolute contents left-[0.51px] mix-blend-screen top-0"></div>
          <div class="absolute border border-[#deca37] border-solid left-[5.53px] size-[85.867px] top-[6.57px]"></div>
          <div class="absolute border-[#deca37] border-[0.5px] border-solid left-[-0.03px] size-[99px] top-0"></div>
        </div>
        <!-- Icon image -->
        <div class="relative shrink-0 size-[32px]">
          <img alt="" class="absolute inset-0 max-w-none object-cover pointer-events-none size-full" src={src}/>
        </div>
      </a>
    ))}
  </div>

  <!-- Background decorative image -->
  <div class="absolute border-4 border-[#f1f1f1] border-solid h-[141px] left-[146px] top-[230px] w-[250px]">
    <img alt="" class="absolute inset-0 max-w-none object-cover opacity-80 pointer-events-none size-full" src={imgImage12}/>
  </div>

</div>
