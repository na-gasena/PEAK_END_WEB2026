---
// メンバーは src/data/members.json で管理（TinaCMSの /admin から編集可能）
import { members, DEFAULT_PERSON_PHOTO } from "../../lib/people";

const base = import.meta.env.BASE_URL;
const imgLine10 = base + "images/d022fcd1d982914490ea0bf4ff6b1ecc4b1d7e0e.svg";

const memberCards = members.map((m) => ({
  ...m,
  photoSrc: base + (m.photo && m.photo.trim() ? m.photo : DEFAULT_PERSON_PHOTO).replace(/^\//, ""),
}));
---
<div class="bg-[#ffffeb] relative size-full h-[1102px] overflow-hidden">
  <div class="-translate-x-1/2 absolute content-stretch flex flex-col gap-[12px] items-center left-1/2 top-[68px] w-full px-[16px]">
    <div class="content-stretch flex flex-col gap-[14px] items-start relative shrink-0 w-[326px]">
      <p class="font-[family-name:var(--mainfont,'Zen_Kaku_Gothic_New:Bold',sans-serif)] h-[27px] leading-[normal] not-italic relative shrink-0 text-[#deca37] text-[14px] text-center w-full">監督：シン・チェリン</p>
      <div class="content-stretch flex flex-col gap-[13px] items-center relative shrink-0 w-full">
        <div class="h-0 relative shrink-0 w-[280px]">
          <div class="absolute inset-[-1px_0_0_0]"><img alt="" class="block max-w-none size-full" src={imgLine10}/></div>
        </div>
        <div class="font-[family-name:var(--mainfont,'Zen_Kaku_Gothic_New:Medium',sans-serif)] h-auto min-w-full not-italic relative shrink-0 text-[#deca37] text-[12px] text-center w-[min-content] whitespace-pre-wrap"><p class="leading-[normal] mb-3">出演：シン・チェリン　伊丹そら</p><p class="leading-[normal] mb-3">撮影：清水歩夢　西尾千裕</p><p class="leading-[normal] mb-3">録音：キム・スビン</p><p class="leading-[normal] mb-3">編集：西尾千裕</p><p class="leading-[normal] mb-3">製作：Team PEAK END </p><p class="leading-[normal]">&nbsp;</p></div>
        <div class="h-0 relative shrink-0 w-[280px]">
          <div class="absolute inset-[-1px_0_0_0]"><img alt="" class="block max-w-none size-full" src={imgLine10}/></div>
        </div>
      </div>
    </div>
    <p class="font-[family-name:var(--mainfont,'Zen_Kaku_Gothic_New:Medium',sans-serif)] h-[34px] leading-[normal] min-w-full not-italic relative shrink-0 text-[#deca37] text-[10px] text-center w-[min-content]">2025年｜日本｜120分｜言語:日本語、韓国語｜</p>
  </div>
  <div class="-translate-x-1/2 absolute font-['Shippori_Antique_B1:Regular',sans-serif] h-[74px] leading-[0] left-[calc(50%+0.5px)] not-italic text-[#deca37] text-[10px] text-center top-[1029px] w-[252px] whitespace-pre-wrap"><p class="leading-[normal] mb-0">&nbsp;</p><p class="leading-[normal] mb-0"> boid/VOICE OF GHOST </p><p class="leading-[normal] mb-0"> </p><p class="leading-[normal]">©PEAK END</p></div>
  <div class="absolute bg-[#deca37] h-[675px] left-0 rounded-[9px] top-[346px] w-[393px]"></div>
  <div class="-translate-x-1/2 absolute bg-[var(--heading,#fefefe)] content-stretch flex items-center justify-center left-[calc(50%+0.5px)] px-[4px] py-[5px] top-[359px]"><div class="flex flex-col font-['Londrina_Solid',sans-serif] justify-center leading-[0] not-italic relative shrink-0 text-[#deca37] text-[20px] text-center whitespace-nowrap"><p class="leading-[77.45000457763672%]"># members</p></div></div>
  <div class="-translate-x-1/2 absolute grid grid-cols-[repeat(2,196px)] inline-grid left-[calc(50%+0.5px)] top-[407px] border-t border-l border-white">
    {memberCards.map((m, i) => (
      <div data-member-card class="content-stretch flex flex-col gap-[10px] items-start p-[9px] relative shrink-0 size-[196px] cursor-pointer group hover:brightness-90 active:opacity-70 transition-[filter,opacity] select-none" onclick={`openModal('modal-member-${i}')`}>
        <div class="absolute border-b border-r border-white content-stretch flex items-start left-0 p-[13px] size-[196px] top-0">
          <div data-member-photo class="relative shrink-0 size-[170px]"><img alt={m.name} class="absolute inset-0 max-w-none object-cover pointer-events-none size-full" src={m.photoSrc}/></div>
        </div>
        <div class="absolute top-[6px] right-[6px] bg-[#deca37] rounded-full size-[20px] flex items-center justify-center z-10 pointer-events-none group-hover:scale-125 transition-transform">
          <svg viewBox="0 0 12 12" class="size-[10px]" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M2 10 L10 2 M5 2 H10 V7" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <div class="bg-[var(--heading,#fefefe)] content-stretch flex items-center px-[4px] relative shrink-0">
          <div class="font-['Shippori_Antique_B1',sans-serif] leading-[0] not-italic relative shrink-0 text-[#deca37] text-[12px] whitespace-nowrap"><p class="leading-[normal] mb-0 whitespace-pre">{m.roleCard} : </p><p class="leading-[normal] whitespace-pre">{m.name}</p></div>
        </div>
      </div>
    ))}
  </div>
  <div class="absolute content-stretch flex flex-col gap-[10px] h-[38px] items-start left-[18px] py-[6px] top-[7px] w-[382px]" style="overflow: hidden;">
    <div class="absolute bg-[rgba(217,107,157,0.6)] h-[25px] w-[275px]" style="left: 107px; top: 6px;"></div>
    <div class="absolute content-stretch flex gap-[6px] items-end leading-[normal] left-0 not-italic text-[#deca37] top-0 whitespace-nowrap">
      <p class="font-['Londrina_Solid',sans-serif] relative shrink-0 text-[32px]">CREDITS</p>
      <div class="overflow-hidden flex-1 relative">
        <div class="animate-ticker relative shrink-0 text-[24px] py-[2px]">
          <div class="content-stretch flex gap-[6px] items-center pr-[6px]">
            <p class="font-['Londrina_Solid',sans-serif] font-light relative shrink-0">CREDITS</p><p class="font-['Londrina_Solid',sans-serif] font-[100] relative shrink-0">CREDITS</p><p class="font-['Londrina_Solid',sans-serif] font-black relative shrink-0">CREDITS</p><p class="font-['Londrina_Solid',sans-serif] relative shrink-0">CREDITS</p><p class="font-['Londrina_Solid',sans-serif] font-light relative shrink-0">CREDITS</p><p class="font-['Londrina_Solid',sans-serif] font-[100] relative shrink-0">CREDITS</p><p class="font-['Londrina_Solid',sans-serif] font-black relative shrink-0">CREDITS</p><p class="font-['Londrina_Solid',sans-serif] relative shrink-0">CREDITS</p>
          </div>
          <div class="content-stretch flex gap-[6px] items-center pr-[6px]" aria-hidden="true">
            <p class="font-['Londrina_Solid',sans-serif] font-light relative shrink-0">CREDITS</p><p class="font-['Londrina_Solid',sans-serif] font-[100] relative shrink-0">CREDITS</p><p class="font-['Londrina_Solid',sans-serif] font-black relative shrink-0">CREDITS</p><p class="font-['Londrina_Solid',sans-serif] relative shrink-0">CREDITS</p><p class="font-['Londrina_Solid',sans-serif] font-light relative shrink-0">CREDITS</p><p class="font-['Londrina_Solid',sans-serif] font-[100] relative shrink-0">CREDITS</p><p class="font-['Londrina_Solid',sans-serif] font-black relative shrink-0">CREDITS</p><p class="font-['Londrina_Solid',sans-serif] relative shrink-0">CREDITS</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  (function () {
    const SCALE   = 1.05;
    const DUR_IN  = '0.28s';
    const DUR_OUT = '0.45s';
    const EASE    = 'cubic-bezier(0.25, 0.46, 0.45, 0.94)';

    const cards = /** @type {HTMLElement[]} */ ([...document.querySelectorAll('[data-member-card]')]);
    const photos = cards.map(card =>
      /** @type {HTMLElement|null} */ (card.querySelector('[data-member-photo]'))
    );
    photos.forEach(p => { if (p) p.style.willChange = 'transform'; });

    /** @type {Record<number, ReturnType<typeof setTimeout>>} */
    const timers = {};

    function scalePhoto(photo, i, scale) {
      if (!photo) return;
      photo.style.transition = `transform ${scale > 1 ? DUR_IN : DUR_OUT} ${EASE}`;
      photo.style.transform  = scale === 1 ? '' : `scale(${scale})`;
    }

    function onScroll() {
      cards.forEach((card, i) => {
        const r = card.getBoundingClientRect();
        if (r.top < window.innerHeight && r.bottom > 0) {
          scalePhoto(photos[i], i, SCALE);
          clearTimeout(timers[i]);
          timers[i] = setTimeout(() => scalePhoto(photos[i], i, 1), 180);
        }
      });
    }

    window.addEventListener('scroll', onScroll, { passive: true });
  })();
</script>
