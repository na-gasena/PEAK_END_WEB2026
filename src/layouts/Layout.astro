---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = "PEAK END", description = "映画『PEAK END』公式サイト" } = Astro.props;
const ogImage = `${import.meta.env.SITE ?? ''}${import.meta.env.BASE_URL}images/OGP.png`;
const splashLogo = import.meta.env.BASE_URL + "images/18e833807e1fcda84c8bb77a6ea04a9c9bccdbdf.png";
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href={import.meta.env.BASE_URL + "images/63e4ec37dcc1d366edcc53ce9a5ae7d1dc8009b3.png"} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Klee+One&family=Londrina+Solid:wght@100;300;400;900&family=Zen+Kaku+Gothic+New:wght@400;500;700&family=Shippori+Antique+B1&display=swap" rel="stylesheet">
  </head>
  <body>
    <!-- Splash Screen -->
    <div id="splash" aria-label="loading">
      <img class="splash-logo" src={splashLogo} alt="PEAK END" />
    </div>

    <slot />
  </body>

  <style>
    #splash {
      position: fixed;
      inset: 0;
      background: #deca37;
      display: grid;
      place-items: center;
      z-index: 9999;
      opacity: 1;
      transition: opacity 0.8s ease;
    }
    #splash.is-hidden {
      opacity: 0;
      pointer-events: none;
    }
    .splash-logo {
      width: min(280px, 68vw);
      max-height: 40vh;
      object-fit: contain;
      filter: drop-shadow(0 4px 12px rgba(0, 0, 0, 0.18));
    }
  </style>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const splash = document.getElementById('splash');
      if (!splash) return;

      const SPLASH_DURATION = 1800;
      const FADE_DURATION   = 800;

      setTimeout(() => {
        splash.classList.add('is-hidden');
        setTimeout(() => {
          splash.style.display = 'none';
        }, FADE_DURATION);
      }, SPLASH_DURATION);
    });
  </script>
</html>
