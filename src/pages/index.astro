---
import Layout from '../layouts/Layout.astro';
import Main from '../components/mobile/Main.astro';
import Trailer from '../components/mobile/Trailer.astro';
import News from '../components/mobile/News.astro';
import About from '../components/mobile/About.astro';
import Kotoba from '../components/mobile/Kotoba.astro';
import Theaters from '../components/mobile/Theaters.astro';
import SNS from '../components/mobile/SNS.astro';
import Credits from '../components/mobile/Credits.astro';

// Old detail modals
import MenuScreen from '../components/09-Menu.astro';
import Comp10 from '../components/10-NewsList.astro';

// News 詳細オーバーレイ（news.json から動的生成）
import NewsDetail from '../components/mobile/NewsDetail.astro';
import { newsItems } from '../lib/news';

// KOTOBA / MEMBERS 詳細オーバーレイ（kotoba.json / members.json から動的生成）
import PersonDetail from '../components/mobile/PersonDetail.astro';
import { kotobaItems, members } from '../lib/people';
---

<Layout title="PEAK END">
  <!--
    Fixed Header: transform() 配下では sticky/fixed がビューポート固定にならないため、
    スケール対象の #mobile-main の外に置き、JS で left/transform を同期する。
  -->
  <div id="sticky-header" class="fixed top-0 z-[100] h-0" style="width:393px; transform-origin:top left;">
    <div class="absolute left-0 top-[16px] w-[216px] h-[69px]">
      <button id="scroll-top-btn" class="w-full h-full cursor-pointer bg-transparent border-none p-0" aria-label="トップに戻る">
        <img alt="Header_PEAKEND" class="w-full h-full object-contain drop-shadow-[0_4px_4px_rgba(0,0,0,0.25)]" src={import.meta.env.BASE_URL + "images/18e833807e1fcda84c8bb77a6ea04a9c9bccdbdf.png"}/>
      </button>
    </div>
    <button id="menu-icon-btn" class="absolute right-[17px] top-[35px] size-[32px] cursor-pointer hover:opacity-80 active:opacity-60 transition-opacity bg-transparent border-none p-0" aria-label="メニューを開く" data-name="MenuIcon">
      <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full" aria-hidden="true">
        <rect x="4" y="7"    width="24" height="3" rx="1.5" fill="#333333"/>
        <rect x="4" y="14.5" width="24" height="3" rx="1.5" fill="#333333"/>
        <rect x="4" y="22"   width="24" height="3" rx="1.5" fill="#333333"/>
      </svg>
    </button>
  </div>

  <!-- Responsive Mobile Scale Wrapper -->
  <div id="mobile-outer" class="w-full overflow-x-hidden">
    <main id="mobile-main" class="relative bg-[#ffffeb] flex flex-col shadow-2xl shrink-0" style="width:393px; transform-origin:top left;">
      <div id="section-main"><Main /></div>
      <div id="section-trailer"><Trailer /></div>
      <div id="section-news"><News /></div>
      <div id="section-about"><About /></div>
      <div id="section-kotoba"><Kotoba /></div>
      <div id="section-theaters"><Theaters /></div>
      <div id="section-sns"><SNS /></div>
      <div id="section-credits"><Credits /></div>
    </main>
  </div>

  <!-- Overlay / Modal Wrappers -->
  <dialog id="modal-menu" class="w-full h-full max-w-[393px] m-auto p-0 bg-transparent border-none open:block overflow-hidden">
    <MenuScreen />
  </dialog>
  <dialog id="modal-10" class="w-full h-full max-w-[480px] m-auto p-[20px] bg-transparent border-none backdrop:bg-black/50 open:block overflow-y-auto overscroll-contain">
    <div class="min-h-full flex items-center justify-center">
      <div class="relative w-full">
        <Comp10 />
        <button type="button" class="absolute top-2 right-2 z-50 w-[32px] h-[32px] flex items-center justify-center bg-white/90 rounded-full text-[20px] leading-none shadow" onclick="this.closest('dialog').close()">&times;</button>
      </div>
    </div>
  </dialog>
  {/* News 詳細オーバーレイ: news.json の各項目から生成（id は表示順に modal-news-0, 1, ...） */}
  {newsItems.map((item, i) => (
    <dialog id={`modal-news-${i}`} class="news-detail-modal w-full h-full max-w-[480px] m-auto p-[20px] bg-transparent border-none backdrop:bg-black/50 open:block overflow-y-auto overscroll-contain">
      <div class="min-h-full flex items-center justify-center">
        <div class="relative w-full">
          <NewsDetail item={item} />
          <button type="button" class="absolute top-2 right-2 z-50 w-[32px] h-[32px] flex items-center justify-center bg-white/90 rounded-full text-[20px] leading-none shadow" onclick="this.closest('dialog').close()">&times;</button>
        </div>
      </div>
    </dialog>
  ))}
  {/* KOTOBA 詳細オーバーレイ: kotoba.json から生成（modal-kotoba-0, 1, ...） */}
  {kotobaItems.map((k, i) => (
    <dialog id={`modal-kotoba-${i}`} class="person-detail-modal w-full h-full max-w-[480px] m-auto p-[20px] bg-transparent border-none backdrop:bg-black/50 open:block overflow-y-auto overscroll-contain">
      <div class="min-h-full flex items-center justify-center">
        <div class="relative w-full">
          <PersonDetail name={k.name} role={k.role} photo={k.photo} body={k.body} tagLabel="# comments" />
          <button type="button" class="absolute top-2 right-2 z-50 w-[32px] h-[32px] flex items-center justify-center bg-white/90 rounded-full text-[20px] leading-none shadow" onclick="this.closest('dialog').close()">&times;</button>
        </div>
      </div>
    </dialog>
  ))}
  {/* MEMBERS 詳細オーバーレイ: members.json から生成（modal-member-0, 1, ...） */}
  {members.map((m, i) => (
    <dialog id={`modal-member-${i}`} class="person-detail-modal w-full h-full max-w-[480px] m-auto p-[20px] bg-transparent border-none backdrop:bg-black/50 open:block overflow-y-auto overscroll-contain">
      <div class="min-h-full flex items-center justify-center">
        <div class="relative w-full">
          <PersonDetail name={m.name} role={m.roleDetail} photo={m.photo} body={m.body} tagLabel="# members" />
          <button type="button" class="absolute top-2 right-2 z-50 w-[32px] h-[32px] flex items-center justify-center bg-white/90 rounded-full text-[20px] leading-none shadow" onclick="this.closest('dialog').close()">&times;</button>
        </div>
      </div>
    </dialog>
  ))}

  <script>
    import rough from 'roughjs';

    // Responsive scale: fit 393px design to viewport width
    const DESIGN_WIDTH = 393;
    const DESKTOP_BREAKPOINT = 520; // phone-frame (inner-scroll) mode threshold
    const FRAME_R = 36;             // border-radius of the phone frame
    const FRAME_PAD = 10;           // SVG overlay extends this many px beyond the frame

    /** Build an SVG rounded-rect path string */
    function rrPath(x, y, w, h, r) {
      const cr = Math.min(r, w / 2, h / 2);
      return `M${x+cr},${y} L${x+w-cr},${y} Q${x+w},${y} ${x+w},${y+cr}`
           + ` L${x+w},${y+h-cr} Q${x+w},${y+h} ${x+w-cr},${y+h}`
           + ` L${x+cr},${y+h} Q${x},${y+h} ${x},${y+h-cr}`
           + ` L${x},${y+cr} Q${x},${y} ${x+cr},${y} Z`;
    }

    /** Draw / redraw the rough double-border SVG overlay */
    function updateFrameOverlay(leftOffset) {
      const P = FRAME_PAD;
      const frameH = window.innerHeight - 48; // frame height (top:24 + bottom:24)
      const svgW = DESIGN_WIDTH + P * 2;
      const svgH = frameH + P * 2;

      let svg = document.getElementById('frame-overlay');
      if (!svg) {
        svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
        svg.id = 'frame-overlay';
        svg.setAttribute('xmlns', 'http://www.w3.org/2000/svg');
        svg.style.cssText = 'pointer-events:none; position:fixed; z-index:99;';
        document.body.appendChild(svg);
      }
      svg.style.display = '';
      svg.style.left    = (leftOffset - P) + 'px';
      svg.style.top     = (24 - P) + 'px';
      svg.setAttribute('width',  svgW);
      svg.setAttribute('height', svgH);
      svg.style.width   = svgW + 'px';
      svg.style.height  = svgH + 'px';
      svg.innerHTML = '';

      const rc = rough.svg(svg);

      // Outer border — outside the frame, on the yellow background
      svg.appendChild(rc.path(
        rrPath(3, 3, svgW - 6, svgH - 6, FRAME_R + P - 3),
        {
          stroke: 'rgba(255,255,255,0.55)',
          strokeWidth: 2.2,
          roughness: 2.4,
          bowing: 1.0,
          fill: 'none',
          disableMultiStroke: false,
        }
      ));

      // Inner border — just inside the frame edge, on top of content
      svg.appendChild(rc.path(
        rrPath(P + 5, P + 5, DESIGN_WIDTH - 10, frameH - 10, FRAME_R - 5),
        {
          stroke: 'rgba(255,255,255,0.88)',
          strokeWidth: 1.6,
          roughness: 1.8,
          bowing: 0.6,
          fill: 'none',
          disableMultiStroke: false,
        }
      ));
    }

    /** Hide the overlay when not in desktop mode */
    function hideFrameOverlay() {
      const svg = document.getElementById('frame-overlay');
      if (svg) svg.style.display = 'none';
    }

    function applyMobileScale() {
      const outer = document.getElementById('mobile-outer');
      const main  = document.getElementById('mobile-main');
      const header = document.getElementById('sticky-header');
      if (!outer || !main) return;
      // Always read the true viewport width (outer may be position:fixed + 393px wide)
      const vw = document.documentElement.clientWidth;

      if (vw >= DESKTOP_BREAKPOINT) {
        // ── Desktop: fixed phone-frame with inner scroll ────
        const leftOffset = Math.max(0, Math.floor((vw - DESIGN_WIDTH) / 2));

        document.body.style.overflow        = 'hidden';
        document.body.style.backgroundColor = '#deca37';

        outer.style.position     = 'fixed';
        outer.style.top          = '24px';
        outer.style.bottom       = '24px';
        outer.style.left         = leftOffset + 'px';
        outer.style.width        = DESIGN_WIDTH + 'px';
        outer.style.height       = '';
        outer.style.overflowY    = 'auto';
        outer.style.overflowX    = 'hidden';
        outer.style.borderRadius = '36px';
        outer.style.boxShadow    = '';
        outer.style.paddingTop   = '';
        outer.style.paddingBottom = '';

        main.style.transform    = 'none';
        main.style.marginLeft   = '0';
        main.style.marginRight  = '0';
        main.style.borderRadius = '';
        main.style.overflow     = '';
        main.style.boxShadow    = '';

        if (header) {
          header.style.transform = 'none';
          header.style.left      = leftOffset + 'px';
          header.style.top       = '20px'; // clear the double-border lines
        }

        updateFrameOverlay(leftOffset);

      } else {
        // ── Mobile: scale to fit viewport width, normal page scroll ──
        document.body.style.overflow        = '';
        document.body.style.backgroundColor = '';

        outer.style.position     = '';
        outer.style.top          = '';
        outer.style.bottom       = '';
        outer.style.left         = '';
        outer.style.width        = '';
        outer.style.overflowY    = 'clip'; // clip = はみ出しを切るがスクロールコンテナを作らない
        outer.style.overflowX    = 'clip'; // overflow-x:hidden のCSS仕様による overflow-y:auto 化を防ぐ
        outer.style.borderRadius = '';
        outer.style.boxShadow    = '';
        outer.style.paddingTop   = '';
        outer.style.paddingBottom = '';

        const scale = vw / DESIGN_WIDTH;
        main.style.transform    = `scale(${scale})`;
        main.style.marginLeft   = '0';
        main.style.marginRight  = '0';
        outer.style.height      = (main.scrollHeight * scale) + 'px';
        main.style.borderRadius = '';
        main.style.overflow     = '';
        main.style.boxShadow    = '';

        if (header) {
          header.style.transform = `scale(${scale})`;
          header.style.top       = '';
          header.style.left      = '0';
        }

        hideFrameOverlay();
      }
    }
    applyMobileScale();
    window.addEventListener('resize', applyMobileScale);

    // Scroll to a section (desktop: inner container / mobile: window)
    window.scrollToSection = function (sectionId) {
      const section = document.getElementById(sectionId);
      if (!section) return;
      const outer = document.getElementById('mobile-outer');
      const main  = document.getElementById('mobile-main');
      document.body.classList.remove('modal-open');
      if (!outer || !main) { section.scrollIntoView({ behavior: 'smooth' }); return; }
      const vw = document.documentElement.clientWidth;
      if (vw >= DESKTOP_BREAKPOINT) {
        outer.scrollTo({ top: section.offsetTop, behavior: 'smooth' });
      } else {
        const scale = vw / DESIGN_WIDTH;
        window.scrollTo({ top: section.offsetTop * scale, behavior: 'smooth' });
      }
    };

    // Utility to open dialogs (+ scroll lock)
    window.openModal = function (id) {
      const dialog = document.getElementById(id);
      if (dialog) {
        dialog.showModal();
        document.body.classList.add('modal-open');
      }
    };

    // モーダルが閉じたら、他に開いているものがなければスクロールロック解除
    document.querySelectorAll('dialog').forEach(d => {
      d.addEventListener('close', () => {
        if (!document.querySelector('dialog[open]')) {
          document.body.classList.remove('modal-open');
        }
      });
    });

    document.addEventListener('DOMContentLoaded', () => {
      applyMobileScale();

      // Scroll to top with smooth animation
      const scrollTopBtn = document.getElementById('scroll-top-btn');
      if (scrollTopBtn) {
        scrollTopBtn.addEventListener('click', () => {
          const vw = document.documentElement.clientWidth;
          const outer = document.getElementById('mobile-outer');
          if (vw >= DESKTOP_BREAKPOINT && outer) {
            outer.scrollTo({ top: 0, behavior: 'smooth' });
          } else {
            window.scrollTo({ top: 0, behavior: 'smooth' });
          }
        });
      }

      // Setup menu icon click (both sticky header and any inside components)
      document.querySelectorAll('[data-name="MenuIcon"]').forEach(icon => {
        icon.style.cursor = 'pointer';
        icon.addEventListener('click', () => window.openModal('modal-menu'));
      });
      // Close menu / NewsList modals（背景クリックで閉じる）
      ['modal-menu','modal-10'].forEach(id => {
        const d = document.getElementById(id);
        if (!d) return;
        d.addEventListener('click', e => {
          const card = d.querySelector(':scope > div');
          // dialog(背景) または padding/gap等の背景色がないコンテナ自身のクリックなら閉じる
          if (e.target === d || e.target === card) {
            setTimeout(() => d.close(), 0);
          }
        });
      });
      // Close news / person (kotoba・members) detail overlays（動的生成。背景クリックで閉じる）
      document.querySelectorAll('.news-detail-modal, .person-detail-modal').forEach(d => {
        d.addEventListener('click', e => {
          const card = d.querySelector(':scope > div');
          if (e.target === d || e.target === card) {
            setTimeout(() => d.close(), 0);
          }
        });
      });
    });
  </script>
</Layout>
